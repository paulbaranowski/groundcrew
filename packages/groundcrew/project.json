{
  "name": "groundcrew",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "packages/groundcrew/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{workspaceRoot}/dist/packages/groundcrew"],
      "options": {
        "command": "tsgo --build packages/groundcrew/tsconfig.lib.json",
        "forwardAllArgs": false
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint packages/groundcrew --deny-warnings",
        "forwardAllArgs": false
      },
      "outputs": []
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "packages/groundcrew/vitest.config.ts"
      }
    }
  }
}
