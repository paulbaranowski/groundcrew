{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint/main/schema/markdownlint-config-schema.json",
  "config": {
    "MD013": false,
    "MD033": {
      "allowed_elements": [
        "a",
        "code",
        "details",
        "h1",
        "img",
        "p",
        "picture",
        "source",
        "summary",
      ],
    },
    "MD041": false,
  },
  "gitignore": true,
  "globs": ["**/*.{md,mdx}"],
  "ignores": [".agents/**"],
}
