{
  "name": "@clipboard/source",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "affected": "nx run-many --configuration ci --targets build,lint,test",
    "cpd": "jscpd .",
    "architecture:check": "depcruise packages",
    "clip:dev": "./packages/clip/bin/dev.js",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "hook:pre-commit": "lint-staged",
    "hook:pre-push": "node --run verify",
    "knip": "knip",
    "lint": "oxlint --deny-warnings",
    "markdown:lint": "markdownlint-cli2",
    "merge-queue:categorize-reasons": "tsx scripts/categorizeMergeQueueReasons.ts",
    "postinstall": "node --run sync-ai-rules",
    "pr:failing-checks": "npx tsx scripts/prFailingChecks.ts",
    "prepare": "husky",
    "spell:check": "cspell  --no-summary --no-progress --no-must-find-files",
    "sync-ai-rules": "node ./node_modules/@clipboard-health/ai-rules/scripts/sync.js common",
    "syncpack:lint": "syncpack lint",
    "test": "vitest run --coverage",
    "verify": "node scripts/verifyAll.mts"
  },
  "devDependencies": {
    "@clipboard-health/ai-rules": "2.18.4",
    "@clipboard-health/oxlint-config": "1.7.0",
    "@nx/js": "22.7.1",
    "@nx/vitest": "22.7.1",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.33",
    "@swc/helpers": "0.5.21",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.12.2",
    "@typescript/native-preview": "7.0.0-dev.20260430.1",
    "@vitest/coverage-v8": "4.1.5",
    "cspell": "10.0.0",
    "dependency-cruiser": "17.4.0",
    "husky": "9.1.7",
    "jscpd": "4.0.9",
    "knip": "6.9.0",
    "lint-staged": "16.4.0",
    "markdownlint-cli2": "0.22.1",
    "nx": "22.7.1",
    "oxfmt": "0.47.0",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.21.1",
    "syncpack": "15.0.0",
    "tslib": "2.8.1",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": "24.14.1",
    "npm": "~11.11.0"
  }
}
